// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model QuoteSnapshot {
  ticker String
  fetchedAt DateTime @default(now()) @map("fetched_at")
  closePrice Float @map("close_price")
  marketCap Float @map("market_cap")
  pl Float
  pvp Float
  evEbitda Float @map("ev_ebitda")
  roe Float
  roic Float
  netMargin Float @map("net_margin")
  grossMargin Float @map("gross_margin")
  netDebtEbitda Float @map("net_debt_ebitda")
  lpa Float
  vpa Float
  ebitda Float

  @@id([ticker, fetchedAt])
  @@map("quote_snapshots")
}